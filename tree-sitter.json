{
  "grammars": [
    {
      "name": "gabc",
      "camelcase": "Gabc",
      "scope": "source.gabc",
      "path": ".",
      "file-types": null,
      "injection-regex": "^gabc$"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "GPLv3",
    "description": "a simple notation based exclusively on ASCII characters that enables the user to describe Gregorian chant scores",
    "authors": [
      {
        "name": "Alex Harter",
        "email": "alex@harter.tech"
      }
    ],
    "links": {
      "repository": "https://github.com/AlexHarter/tree-sitter-gabc"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}